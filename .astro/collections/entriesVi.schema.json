{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name_vi": {
      "type": "string"
    },
    "name_han": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "name_en": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "subcategories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "type": {
      "type": "string"
    },
    "gender": {
      "type": "string"
    },
    "era": {
      "type": "string"
    },
    "era_mythic": {
      "type": "string"
    },
    "era_historic": {
      "type": "string"
    },
    "year_approx": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "year_note": {
      "type": "string"
    },
    "year_end": {
      "type": "number"
    },
    "region": {
      "type": "string"
    },
    "sovereignty_relevant": {
      "type": "boolean"
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "location_modern": {
      "type": "string"
    },
    "coordinates": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "geography": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "relations": {
      "type": "object",
      "properties": {
        "family": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "enemies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "teachers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allied_historical": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cohabitors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mythic_events": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "historic_events": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "related_sites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "chapter": {
            "type": "string"
          },
          "edition": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "title"
        ]
      }
    },
    "summary": {
      "type": "string"
    },
    "group": {
      "type": "string"
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "text_primary": {
      "type": "string"
    },
    "cult_center": {
      "type": "string"
    },
    "heritage_status": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "archaeological_note": {
      "type": "string"
    },
    "scholarly_debates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "popularity": {
      "default": 1,
      "type": "number"
    },
    "status": {
      "default": "published",
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name_vi",
    "category"
  ]
}