{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name_vi": {
      "type": "string"
    },
    "name_han": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "name_en": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "subcategories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gender": {
      "type": "string"
    },
    "era": {
      "type": "string"
    },
    "year_approx": {
      "type": "number"
    },
    "year_end": {
      "type": "number"
    },
    "region": {
      "type": "string"
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "coordinates": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "relations": {
      "type": "object",
      "properties": {
        "family": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "enemies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "chapter": {
            "type": "string"
          },
          "edition": {
            "type": "string"
          }
        },
        "required": [
          "title"
        ]
      }
    },
    "summary": {
      "type": "string"
    },
    "group": {
      "type": "string"
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "popularity": {
      "default": 1,
      "type": "number"
    },
    "status": {
      "default": "published",
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name_vi",
    "category"
  ]
}