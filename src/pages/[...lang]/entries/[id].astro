---
import EntryLayout from '../../../layouts/EntryLayout.astro';
import { getLocalizedEntries } from '../../../i18n/content';
import { localeStaticPaths } from '../../../i18n/paths';
import type { Locale } from '../../../i18n/config';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const paths = [];

  for (const path of localeStaticPaths()) {
    const lang = path.props.lang as Locale;
    const entries = await getLocalizedEntries(lang);
    const published = entries.filter((e) => e.data.status === 'published');

    for (const entry of published) {
      paths.push({
        params: { ...path.params, id: entry.id },
        props: {
          lang,
          entry,
          allEntries: published,
          related: published
            .filter((e) => e.id !== entry.id)
            .sort((a, b) => (b.data.popularity ?? 1) - (a.data.popularity ?? 1))
            .slice(0, 3),
        },
      });
    }
  }

  return paths;
}

const { entry, related, lang, allEntries } = Astro.props as {
  entry: any;
  related: any[];
  lang: Locale;
  allEntries: any[];
};
const { Content } = await render(entry);
---
<EntryLayout entry={entry} related={related} lang={lang} allEntries={allEntries}>
  <Content />
</EntryLayout>
