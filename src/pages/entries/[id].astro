---
import EntryLayout from '../../layouts/EntryLayout.astro';
import { getLocalizedEntries } from '../../i18n/content';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const lang = 'vi' as const;
  const paths = [];
  const entries = await getLocalizedEntries(lang);
  const published = entries.filter((e) => e.data.status === 'published');
  for (const entry of published) {
    paths.push({
      params: { id: entry.id },
      props: {
        entry,
        related: published
          .filter((e) => e.id !== entry.id)
          .sort((a, b) => (b.data.popularity ?? 1) - (a.data.popularity ?? 1))
          .slice(0, 3),
      },
    });
  }
  return paths;
}

const lang = 'vi' as const;
const { entry, related } = Astro.props as { entry: any; related: any[] };
const { Content } = await render(entry);
---
<EntryLayout entry={entry} related={related} lang={lang}>
  <Content />
</EntryLayout>
