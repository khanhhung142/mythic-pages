---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalizedEntries } from '../../i18n/content';
import { getCategoryLabel, CATEGORY_SLUGS } from '../../data/category-labels';
import { t, locales } from '../../i18n/config';
import type { Locale } from '../../i18n/config';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };

const allEntries = await getLocalizedEntries(lang);
const shuffled = [...allEntries];
for (let i = shuffled.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
}
const featured = shuffled[0];
const sideEntries = shuffled.slice(1, 4);

type CatMeta = { num: string; han: string; desc: Record<Locale, string> };
const categoryMeta: Record<string, CatMeta> = {
  'than-linh': { num: 'i.',    han: '神 — Deities',    desc: { vi: 'Các vị thần trong tín ngưỡng dân gian, từ thần núi sông đến thần bếp.',       en: 'Folk deities from mountain gods to kitchen spirits.' } },
  'anh-hung':  { num: 'ii.',   han: '英雄 — Heroes',    desc: { vi: 'Anh hùng và danh nhân huyền thoại, người mang sứ mệnh giữ nước.',             en: 'Legendary heroes and champions who defended the nation.' } },
  'yeu-quai':  { num: 'iii.',  han: '妖怪 — Demons',    desc: { vi: 'Quỷ dữ, hồ tinh, và những linh hồn lang thang trong rừng thiêng.',           en: 'Demons, fox spirits, and wandering souls of sacred forests.' } },
  'linh-vat':  { num: 'iv.',   han: '靈獸 — Beasts',    desc: { vi: 'Tứ linh Long-Lân-Quy-Phụng và những sinh vật thần kỳ khác.',                en: 'The Four Sacred Beasts and other mythical creatures.' } },
  'dia-danh':  { num: 'v.',    han: '地名 — Places',    desc: { vi: 'Núi Tản Viên, hồ Hoàn Kiếm, thành Cổ Loa — đất thiêng của truyền thuyết.',   en: 'Tản Viên mountain, Hoàn Kiếm lake — sacred lands of legend.' } },
  'vat-pham':  { num: 'vi.',   han: '寶物 — Artifacts', desc: { vi: 'Nỏ thần, gậy thần, sách ước — những bảo vật mang sức mạnh siêu nhiên.',      en: 'Magic crossbow, divine staff — artifacts of supernatural power.' } },
  'le-hoi':    { num: 'vii.',  han: '祭禮 — Festivals', desc: { vi: 'Hội Gióng, hội Đền Hùng, lễ hội cổ truyền còn vang vọng đến hôm nay.',      en: 'Gióng festival, Hùng Temple festival — ancient traditions alive today.' } },
  'tich-co':   { num: 'viii.', han: '古事 — Tales',     desc: { vi: 'Sự tích trầu cau, bánh chưng bánh giầy — những câu chuyện đầu đời.',          en: 'Betel nut, sticky rice cake tales — stories from the beginning.' } },
};
---
<BaseLayout title={t(lang, 'site.title')} lang={lang}>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="eyebrow">{t(lang, 'hero.eyebrow')}</div>
      <h1>{t(lang, 'hero.title1')}<em>{t(lang, 'hero.title2')}</em></h1>
      <p class="hero-lead">{t(lang, 'hero.lead')}</p>
      <div class="cta-row">
        <a href={`/${lang}/entries`} class="btn-primary"><span>{t(lang, 'hero.cta.explore')}</span></a>
        <a href="#featured" class="btn-secondary">{t(lang, 'hero.cta.featured')}</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-caption">{t(lang, 'hero.caption')}</div>
      <div class="img-placeholder hero-img-main"></div>
      <div class="img-placeholder hero-img-accent"></div>
    </div>
  </section>

  <!-- Featured -->
  <section class="section" id="featured">
    <div class="section-header">
      <h2 class="section-title">{t(lang, 'featured.title1')}<em>{t(lang, 'featured.title2')}</em></h2>
      <a href={`/${lang}/entries`} class="section-link">{t(lang, 'featured.viewAll')}</a>
    </div>
    <div class="featured-grid">
      {featured && (
        <a href={`/${lang}/entries/${featured.id}`} class="featured-main">
          <div class="img-placeholder featured-img"></div>
          <div class="featured-text">
            <div class="featured-tags">
              <span class="tag primary">{getCategoryLabel(featured.data.category, lang)}</span>
            </div>
            <h3>{featured.data.name_vi}</h3>
            {featured.data.name_han && <div class="subtitle">{featured.data.name_han} — {featured.data.name_en}</div>}
            <p>{featured.data.summary}</p>
          </div>
        </a>
      )}
      <div class="featured-side">
        {sideEntries.map(entry => (
          <a href={`/${lang}/entries/${entry.id}`} class="side-card">
            <div class="img-placeholder"></div>
            <div>
              <div class="meta">{getCategoryLabel(entry.data.category, lang)}</div>
              <h4>{entry.data.name_vi}</h4>
              <p>{entry.data.summary?.slice(0, 120)}...</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="section categories" id="categories">
    <div class="section-header">
      <h2 class="section-title">{t(lang, 'categories.title1')}<em>{t(lang, 'categories.title2')}</em></h2>
      <a href={`/${lang}/entries`} class="section-link">{t(lang, 'categories.viewAll')}</a>
    </div>
    <div class="cat-grid">
      {CATEGORY_SLUGS.map(slug => {
        const cat = categoryMeta[slug];
        if (!cat) return null;
        return (
          <a href={`/${lang}/entries/category/${slug}`} class="cat-card">
            <div class="cat-num">{cat.num}</div>
            <div>
              <h3>{getCategoryLabel(slug, lang)}</h3>
              <div class="han">{cat.han}</div>
              <p>{cat.desc[lang]}</p>
            </div>
            <div class="arrow">→</div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Quote -->
  <section class="quote" id="quote">
    <blockquote>{t(lang, 'quote.content')}</blockquote>
    <cite>— {t(lang, 'quote.source')}</cite>
  </section>

</BaseLayout>

<style>
.section{padding:6rem 3rem;position:relative}
.section-header{
  display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;
  gap:2rem;
  margin-bottom:4rem;
  padding-bottom:1.5rem;
  border-bottom:1px solid rgba(26,15,8,.2);
}
.section-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,5vw,4rem);font-weight:500;line-height:1}
.section-title em{font-family:'Playfair Display',serif;font-style:italic;color:var(--vermilion)}
.section-link{font-size:.8rem;letter-spacing:.2em;text-transform:uppercase;color:var(--ink);text-decoration:none;border-bottom:1px solid var(--ink);padding-bottom:2px}

.hero{
  min-height:100vh;
  padding:8rem 3rem 4rem;
  display:grid;
  grid-template-columns:1.1fr .9fr;
  gap:4rem;
  align-items:center;
  position:relative;
  overflow:hidden;
}
.hero::before{
  content:'神話';
  position:absolute;top:15%;right:-3%;
  font-family:'Cormorant Garamond',serif;
  font-size:28rem;color:rgba(168,50,30,.04);font-weight:700;line-height:.8;
  pointer-events:none;user-select:none;
}
.hero-content{position:relative;z-index:2;animation:fadeUp 1.2s ease}
.eyebrow{
  font-size:.75rem;letter-spacing:.4em;text-transform:uppercase;
  color:var(--vermilion);margin-bottom:1.5rem;
  display:flex;align-items:center;gap:1rem;
}
.eyebrow::before{content:'';width:40px;height:1px;background:var(--vermilion)}
.hero h1{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(3.5rem,8vw,7rem);font-weight:500;line-height:.95;
  color:var(--ink);margin-bottom:1.5rem;letter-spacing:-.02em;
}
.hero h1 em{
  font-family:'Playfair Display',serif;font-style:italic;font-weight:400;
  color:var(--vermilion);display:block;
}
.hero-lead{
  font-size:1.05rem;line-height:1.65;
  color:var(--ink-soft);max-width:36rem;
  margin:0 0 2rem;
}
.cta-row{display:flex;gap:1rem;align-items:center}
.btn-primary{
  display:inline-flex;align-items:center;gap:.8rem;
  padding:1.1rem 2rem;background:var(--ink);color:var(--paper);
  text-decoration:none;font-size:.85rem;letter-spacing:.2em;text-transform:uppercase;
  transition:all .4s ease;position:relative;overflow:hidden;
}
.btn-primary::before{
  content:'';position:absolute;inset:0;background:var(--vermilion);
  transform:translateY(100%);transition:transform .4s ease;
}
.btn-primary span{position:relative;z-index:1}
.btn-primary:hover::before{transform:translateY(0)}
.btn-secondary{
  color:var(--ink);text-decoration:none;
  font-size:.85rem;letter-spacing:.2em;text-transform:uppercase;
  border-bottom:1px solid var(--ink);padding-bottom:2px;
}
.hero-visual{position:relative;height:75vh;animation:fadeUp 1.2s ease .2s backwards}
.img-placeholder{
  background:linear-gradient(135deg,var(--paper-dark),#d4c19a);
  position:relative;overflow:hidden;
  border:1px solid rgba(26,15,8,.15);
}
.img-placeholder::before{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(45deg,transparent,transparent 20px,rgba(26,15,8,.03) 20px,rgba(26,15,8,.03) 21px);
}
.img-placeholder::after{
  content:'圖';position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  font-family:'Cormorant Garamond',serif;font-size:4rem;color:rgba(26,15,8,.15);
}
.hero-img-main{position:absolute;top:0;right:0;width:75%;height:100%}
.hero-img-accent{position:absolute;bottom:-2rem;left:0;width:45%;height:40%;border:8px solid var(--paper);box-shadow:0 20px 60px var(--shadow)}
.hero-caption{
  position:absolute;top:1rem;left:0;
  writing-mode:vertical-rl;
  font-family:'Playfair Display',serif;font-style:italic;font-size:.9rem;
  color:var(--ink-soft);letter-spacing:.1em;
}

.featured-grid{display:grid;grid-template-columns:1.3fr 1fr;gap:3rem}
.featured-main{
  background:var(--paper-dark);position:relative;cursor:pointer;transition:transform .5s ease;
  text-decoration:none;color:inherit;display:block
}
.featured-main:hover{transform:translateY(-8px)}
.featured-img{height:520px;position:relative}
.featured-text{padding:2.5rem}
.featured-tags{display:flex;gap:.6rem;margin-bottom:1rem;flex-wrap:wrap}
.tag{font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;padding:.4rem .9rem;border:1px solid var(--ink);color:var(--ink)}
.tag.primary{background:var(--vermilion);border-color:var(--vermilion);color:var(--paper)}
.featured-main h3{font-family:'Cormorant Garamond',serif;font-size:3rem;font-weight:500;line-height:1;margin-bottom:.5rem}
.featured-main .subtitle{font-family:'Playfair Display',serif;font-style:italic;color:var(--ink-soft);margin-bottom:1rem}
.featured-main p{color:var(--ink-soft);font-size:1rem;max-width:560px}
.featured-side{display:flex;flex-direction:column;gap:2rem}
.side-card{
  display:grid;grid-template-columns:120px 1fr;gap:1.5rem;cursor:pointer;transition:transform .4s ease;
  text-decoration:none;color:inherit
}
.side-card:hover{transform:translateX(8px)}
.side-card .img-placeholder{height:140px}
.side-card h4{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:600;margin-bottom:.3rem;line-height:1.1;color:var(--ink)}
.side-card:hover h4{color:var(--vermilion)}
.side-card .meta{font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:var(--vermilion);margin-bottom:.5rem}
.side-card p{font-size:.85rem;color:var(--ink-soft);line-height:1.5}

.categories{background:var(--ink);color:var(--paper);position:relative}
.categories::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.categories .section-header{border-color:rgba(244,234,213,.2)}
.categories .section-title em{color:var(--gold)}
.categories .section-link{color:var(--paper);border-color:var(--paper)}
.cat-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:0;
  border-top:1px solid rgba(244,234,213,.15);border-left:1px solid rgba(244,234,213,.15);
}
.cat-card{
  border-right:1px solid rgba(244,234,213,.15);border-bottom:1px solid rgba(244,234,213,.15);
  padding:2.5rem 2rem;cursor:pointer;position:relative;transition:background .4s ease;
  min-height:240px;display:flex;flex-direction:column;justify-content:space-between;
  text-decoration:none;color:var(--paper);
}
.cat-card:hover{background:rgba(168,50,30,.15)}
.cat-card:hover .cat-num{color:var(--vermilion)}
.cat-num{font-family:'Cormorant Garamond',serif;font-size:.9rem;font-style:italic;color:var(--gold);transition:color .3s}
.cat-card h3{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:500;line-height:1;margin:1rem 0 .5rem}
.han{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--gold);font-style:italic;margin-bottom:1rem}
.cat-card p{font-size:.85rem;color:rgba(244,234,213,.7);line-height:1.5}
.arrow{position:absolute;top:2rem;right:2rem;font-size:1.2rem;opacity:0;transform:translateX(-10px);transition:all .4s ease}
.cat-card:hover .arrow{opacity:1;transform:translateX(0)}

.quote{padding:8rem 3rem;text-align:center;position:relative}
.quote::before,.quote::after{content:'';position:absolute;left:50%;width:1px;height:60px;background:var(--vermilion)}
.quote::before{top:3rem}
.quote::after{bottom:3rem}
.quote blockquote{
  font-family:'Playfair Display',serif;font-style:italic;
  font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:400;
  max-width:900px;margin:0 auto 2rem;line-height:1.3;color:var(--ink);
}
.quote blockquote::before{content:'"';color:var(--vermilion);font-size:1.2em}
.quote blockquote::after{content:'"';color:var(--vermilion);font-size:1.2em}
.quote cite{font-size:.8rem;letter-spacing:.3em;text-transform:uppercase;color:var(--ink-soft);font-style:normal}

@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}

@media (max-width:900px){
  .hero{grid-template-columns:1fr;padding:7rem 1.5rem 3rem;gap:3rem}
  .hero-visual{height:60vh}
  .section{padding:4rem 1.5rem}
  .section-header{flex-direction:column;align-items:flex-start;gap:1rem}
  .featured-grid{grid-template-columns:1fr}
  .cat-grid{grid-template-columns:1fr 1fr}
  .featured-img{height:300px}
}
</style>
