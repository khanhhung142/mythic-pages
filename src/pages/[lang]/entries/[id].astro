---
import EntryLayout from '../../../layouts/EntryLayout.astro';
import { getLocalizedEntries } from '../../../i18n/content';
import { render } from 'astro:content';
import { locales } from '../../../i18n/config';
import type { Locale } from '../../../i18n/config';

export async function getStaticPaths() {
  const paths = [];
  for (const lang of locales) {
    const entries = await getLocalizedEntries(lang);
    const published = entries.filter((e) => e.data.status === 'published');
    for (const entry of published) {
      paths.push({
        params: { lang, id: entry.id },
        props: {
          entry,
          lang,
          related: published
            .filter((e) => e.id !== entry.id)
            .sort((a, b) => (b.data.popularity ?? 1) - (a.data.popularity ?? 1))
            .slice(0, 3),
        },
      });
    }
  }
  return paths;
}

const { entry, lang, related } = Astro.props as { entry: any; lang: Locale; related: any[] };
const { Content } = await render(entry);
---
<EntryLayout entry={entry} related={related} lang={lang}>
  <Content />
</EntryLayout>
