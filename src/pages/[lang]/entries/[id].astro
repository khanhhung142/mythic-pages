---
import EntryLayout from '../../../layouts/EntryLayout.astro';
import { getLocalizedEntries } from '../../../i18n/content';
import { defaultLocale, locales } from '../../../i18n/config';
import type { Locale } from '../../../i18n/config';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const paths = [];
  const targetLocales = locales.filter((locale) => locale !== defaultLocale);

  for (const lang of targetLocales) {
    const entries = await getLocalizedEntries(lang);
    const published = entries.filter((e) => e.data.status === 'published');

    for (const entry of published) {
      paths.push({
        params: { lang, id: entry.id },
        props: {
          lang,
          entry,
          related: published
            .filter((e) => e.id !== entry.id)
            .sort((a, b) => (b.data.popularity ?? 1) - (a.data.popularity ?? 1))
            .slice(0, 3),
        },
      });
    }
  }

  return paths;
}

const { entry, related, lang } = Astro.props as { entry: any; related: any[]; lang: Locale };
const { Content } = await render(entry);
---
<EntryLayout entry={entry} related={related} lang={lang}>
  <Content />
</EntryLayout>
