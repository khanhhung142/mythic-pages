---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { alternateLocalePath } from '../i18n/paths';
import type { Locale } from '../i18n/config';

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
}
const { title, description, lang = 'vi' } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const altViPath = alternateLocalePath(Astro.url.pathname, 'vi');
const altEnPath = alternateLocalePath(Astro.url.pathname, 'en');
const altViURL = new URL(altViPath, Astro.site);
const altEnURL = new URL(altEnPath, Astro.site);
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang="vi" href={altViURL.href} />
    <link rel="alternate" hreflang="en" href={altEnURL.href} />
    <link rel="alternate" hreflang="x-default" href={altViURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'vi' ? 'vi_VN' : 'en_US'} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="Thần Thoại Việt Nam" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Be+Vietnam+Pro:wght@300;400;500;600&family=Playfair+Display:ital,wght@1,400;1,600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
