---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Kho lưu trữ thần thoại và truyền thuyết Việt Nam' } = Astro.props;
---
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-[#1A1A1A] font-sans">
    <nav class="border-b border-[#E5E7EB] bg-white sticky top-0 z-10">
      <div class="max-w-[1200px] mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="font-medium text-[15px] text-[#1A1A1A] tracking-tight font-sans">Thần Thoại Việt</a>
        <div class="flex gap-6">
          <a href="/" class="text-[13px] text-[#6B7280] hover:text-[#185FA5] transition-colors font-sans">Trang chủ</a>
          <a href="/entries" class="text-[13px] text-[#6B7280] hover:text-[#185FA5] transition-colors font-sans">Mục lục</a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="border-t border-[#E5E7EB] mt-16 py-8 text-center text-[13px] text-[#9CA3AF] font-sans">
      <p>Thần Thoại Việt Nam — Lưu giữ di sản văn hóa dân tộc</p>
    </footer>
  </body>
</html>
