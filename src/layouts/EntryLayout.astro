---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RelationMiniGraph from '../components/RelationMiniGraph.astro';
import { getCategoryLabel } from '../data/category-labels';
import { defaultLocale, locales, t } from '../i18n/config';
import { localePath, alternateLocalePath } from '../i18n/paths';
import type { Locale } from '../i18n/config';

interface Props {
  entry: any;
  related?: any[];
  lang?: Locale;
  allEntries?: any[];
}

const { entry, related = [], lang = 'vi', allEntries = [] } = Astro.props;
const { data } = entry;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const alternateUrls = locales.map((locale) => ({
  locale,
  href: new URL(alternateLocalePath(Astro.url.pathname, locale), Astro.site).href,
}));
const defaultLocaleHref =
  alternateUrls.find((item) => item.locale === defaultLocale)?.href ?? canonicalURL.href;
const ogLocale = lang === 'vi' ? 'vi_VN' : lang === 'en' ? 'en_US' : lang;
const pageDescription = data.summary ?? data.name_en ?? data.name_vi;

const categoryLabel = getCategoryLabel(data.category, lang);
const hanChar = data.name_han?.charAt(0) ?? '';

function formatApproxYear(y: number, locale: Locale): string {
  if (locale === 'vi') {
    if (y < 0) return `khoảng ${Math.abs(y)} TCN`;
    return String(y);
  }
  if (y < 0) return `c. ${Math.abs(y)} BCE`;
  return `${y} CE`;
}

let approxYearValue: string | undefined;
const yearApprox = data.year_approx;
if (typeof yearApprox === 'number' && Number.isFinite(yearApprox)) {
  approxYearValue = formatApproxYear(yearApprox, lang);
} else if (typeof yearApprox === 'string' && yearApprox.trim()) {
  approxYearValue = yearApprox.trim();
} else if (yearApprox == null) {
  approxYearValue = lang === 'vi' ? 'không có dữ liệu' : 'unknown';
}
if (approxYearValue && data.year_note) approxYearValue = `${approxYearValue} — ${data.year_note}`;

const genderKey = data.gender ? `gender.${data.gender}` : '';
const genderLookup = genderKey ? t(lang, genderKey) : '';
const genderLabel =
  data.gender && genderLookup !== genderKey ? genderLookup : (data.gender ?? '');

const infoRows = [
  data.category ? { label: t(lang, 'entry.type'), value: categoryLabel, isLink: false } : null,
  data.type ? { label: t(lang, 'entry.recordType'), value: data.type, isLink: false } : null,
  data.gender ? { label: t(lang, 'entry.gender'), value: genderLabel ?? '', isLink: false } : null,
  data.era ? { label: t(lang, 'entry.era'), value: data.era, isLink: false } : null,
  data.era_mythic ? { label: t(lang, 'entry.eraMythic'), value: data.era_mythic, isLink: false } : null,
  data.era_historic ? { label: t(lang, 'entry.eraHistoric'), value: data.era_historic, isLink: false } : null,
  approxYearValue ? { label: t(lang, 'entry.approxYear'), value: approxYearValue, isLink: false } : null,
  data.region ? { label: t(lang, 'entry.region'), value: t(lang, `region.${data.region}`), isLink: false } : null,
  data.locations?.length ? { label: t(lang, 'entry.location'), value: data.locations[0], isLink: true } : null,
  data.group ? { label: t(lang, 'entry.group'), value: data.group, isLink: false } : null,
  data.location_modern
    ? { label: t(lang, 'entry.locationModern'), value: data.location_modern, isLink: false }
    : null,
  data.text_primary ? { label: t(lang, 'entry.textPrimary'), value: data.text_primary, isLink: false } : null,
  data.cult_center ? { label: t(lang, 'entry.cultCenter'), value: data.cult_center, isLink: false } : null,
  data.archaeological_note
    ? { label: t(lang, 'entry.archaeologicalNote'), value: data.archaeological_note, isLink: false }
    : null,
].filter(Boolean) as { label: string; value: string; isLink: boolean }[];

const geographyEntries = data.geography ? Object.entries(data.geography as Record<string, string>) : [];

const relGroups = [
  { label: t(lang, 'entry.family'), items: data.relations?.family },
  { label: t(lang, 'entry.teachers'), items: data.relations?.teachers },
  { label: t(lang, 'entry.allies'), items: data.relations?.allies },
  { label: t(lang, 'entry.cohabitors'), items: data.relations?.cohabitors },
  { label: t(lang, 'entry.alliedHistorical'), items: data.relations?.allied_historical },
  { label: t(lang, 'entry.enemies'), items: data.relations?.enemies },
  { label: t(lang, 'entry.artifacts'), items: data.relations?.artifacts },
  { label: t(lang, 'entry.mythicEvents'), items: data.relations?.mythic_events },
  { label: t(lang, 'entry.historicEvents'), items: data.relations?.historic_events },
  { label: t(lang, 'entry.relatedSites'), items: data.relations?.related_sites },
].filter((g) => g.items?.length) as { label: string; items: string[] }[];

function slugToLabel(slug: string): string {
  return slug.replace(/-/g, ' ');
}
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={pageDescription} />
  <title>{data.name_vi} — {t(lang, 'site.title')}</title>
  <link rel="canonical" href={canonicalURL.href} />
  {alternateUrls.map((item) => (
    <link rel="alternate" hreflang={item.locale} href={item.href} />
  ))}
  <link rel="alternate" hreflang="x-default" href={defaultLocaleHref} />
  <meta property="og:type" content="article" />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:title" content={`${data.name_vi} — ${t(lang, 'site.title')}`} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:site_name" content="Thần Thoại Việt Nam" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={`${data.name_vi} — ${t(lang, 'site.title')}`} />
  <meta name="twitter:description" content={pageDescription} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Be+Vietnam+Pro:wght@300;400;500;600&family=Playfair+Display:ital,wght@1,400;1,600&display=swap" rel="stylesheet" />
</head>
<body>

<Header lang={lang} />

<header class="entry-head" data-han={hanChar}>
  <div class="breadcrumb">
    <a href={localePath(lang, '/')}>Wiki</a>
    <span class="sep">/</span>
    <a href={data.category ? localePath(lang, `/entries/category/${data.category}`) : localePath(lang, '/entries')}>{categoryLabel}</a>
    <span class="sep">/</span>
    <span class="current">{data.name_vi}</span>
  </div>

  {data.group && (
    <div class="eyebrow">{data.group}</div>
  )}

  <h1 class="entry-title">{data.name_vi}</h1>

  {data.aliases && data.aliases.length > 0 && (
    <div class="alt-names">{data.aliases.join(' · ')}</div>
  )}

  {(data.name_han || data.name_en) && (
    <div class="han-en">
      {data.name_han && <span class="han">{data.name_han}</span>}
      {data.name_en && <span>· {data.name_en}</span>}
    </div>
  )}

  <div class="tag-row">
    {data.category && <span class="tag primary">{categoryLabel}</span>}
    {data.region && <span class="tag region">{t(lang, `region.${data.region}`)}</span>}
    {data.era && <span class="tag">{data.era}</span>}
  </div>
</header>

<div class="main-grid">

  <article>

    <div class="hero-img">
      <div class="hero-img-caption">{data.name_vi}</div>
    </div>

    {data.summary && (
      <div class="summary">
        <p>{data.summary}</p>
      </div>
    )}

    <div class="entry-content">
      <slot />
    </div>

    {data.sources && data.sources.length > 0 && (
      <div class="sources">
        <div class="section-label">{t(lang, 'entry.sources')}</div>
        <ol>
          {data.sources.map((src: any) => (
            <li>
              {src.author && <Fragment>{src.author}. </Fragment>}
              <em>{src.title}</em>
              {src.chapter && <Fragment>. {src.chapter}</Fragment>}
              {src.edition && <Fragment>. {src.edition}</Fragment>}.
              {src.notes && <p class="source-note">{src.notes}</p>}
            </li>
          ))}
        </ol>
      </div>
    )}

    {related.length > 0 && (
      <div class="related">
        <div class="section-label">{t(lang, 'entry.readMore')}</div>
        <div class="related-grid">
          {related.map((e: any) => (
            <a href={localePath(lang, `/entries/${e.id}`)} class="related-card">
              <div class="img-ph"></div>
              <div class="meta">{getCategoryLabel(e.data.category, lang)}</div>
              <h4>{e.data.name_vi}</h4>
              <p>{e.data.summary ?? ''}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    {allEntries.length > 0 && (
      <RelationMiniGraph entry={entry} allEntries={allEntries} lang={lang} />
    )}

  </article>

  <aside>
    <div class="sidebar-sticky">

      <div class="side-card">
        <div class="side-label">{t(lang, 'entry.info')} <span class="num">i.</span></div>
        <dl class="info-table">
          {infoRows.map((row) => (
            <div class="info-row">
              <dt>{row.label}</dt>
              <dd>
                {row.isLink
                  ? <a href="#">{row.value}</a>
                  : row.value
                }
              </dd>
            </div>
          ))}
          {geographyEntries.map(([geoKey, geoVal]) => (
            <div class="info-row">
              <dt class="geo-key">{geoKey.replace(/_/g, ' ')}</dt>
              <dd>{geoVal}</dd>
            </div>
          ))}
        </dl>
      </div>

      {relGroups.length > 0 && (
        <div class="side-card">
          <div class="side-label">{t(lang, 'entry.related')} <span class="num">ii.</span></div>
          {relGroups.map((group) => (
            <div class="rel-group">
              <h6>{group.label}</h6>
              <div class="items">
                {group.items.map((item: string, i: number) => (
                  <>
                    <a href="#">{item}</a>
                    {i < group.items.length - 1 && <span class="sep">·</span>}
                  </>
                ))}
              </div>
            </div>
          ))}
        </div>
      )}

      {data.themes && data.themes.length > 0 && (
        <div class="side-card">
          <div class="side-label">{t(lang, 'entry.themes')} <span class="num">iii.</span></div>
          <div class="themes">
            {data.themes.map((tag: string) => (
              <span class="theme-tag">{slugToLabel(tag)}</span>
            ))}
          </div>
        </div>
      )}

      {(data.heritage_status?.length || data.scholarly_debates?.length) ? (
        <div class="side-card">
          {data.heritage_status?.length ? (
            <div class="meta-block">
              <div class="side-sub">{t(lang, 'entry.heritageStatus')}</div>
              <ul class="meta-list">
                {data.heritage_status.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ) : null}
          {data.scholarly_debates?.length ? (
            <div class="meta-block">
              <div class="side-sub">{t(lang, 'entry.scholarlyDebates')}</div>
              <ul class="meta-list">
                {data.scholarly_debates.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ) : null}
        </div>
      ) : null}

    </div>
  </aside>

</div>

<Footer lang={lang} />

</body>
</html>

<style is:global>
a{color:inherit;text-decoration:none}

/* HEADER */
header.entry-head{
  padding:8rem 3rem 3rem;
  max-width:1400px;
  margin:0 auto;
  position:relative;
}
header.entry-head::before{
  content:attr(data-han);
  position:absolute;
  top:6rem;right:3rem;
  font-family:'Cormorant Garamond',serif;
  font-size:24rem;
  color:rgba(168,50,30,.05);
  font-weight:700;
  line-height:.8;
  pointer-events:none;
}
.breadcrumb{
  font-size:.75rem;
  letter-spacing:.15em;text-transform:uppercase;
  color:var(--ink-mute);
  margin-bottom:2rem;
  display:flex;align-items:center;gap:.7rem;
}
.breadcrumb a{transition:color .3s}
.breadcrumb a:hover{color:var(--vermilion)}
.breadcrumb .sep{color:var(--ink-light)}
.breadcrumb .current{color:var(--ink)}
.eyebrow{
  font-size:.75rem;
  letter-spacing:.4em;text-transform:uppercase;
  color:var(--vermilion);
  margin-bottom:1.5rem;
  display:flex;align-items:center;gap:1rem;
}
.eyebrow::before{content:'';width:40px;height:1px;background:var(--vermilion)}
.entry-title{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(3.5rem,8vw,6.5rem);
  font-weight:500;
  line-height:.95;
  letter-spacing:-.02em;
  margin-bottom:1rem;
  position:relative;z-index:2;
}
.alt-names{
  font-family:'Playfair Display',serif;
  font-style:italic;
  font-size:1.15rem;
  color:var(--ink-soft);
  margin-bottom:.5rem;
}
.han-en{
  font-family:'Cormorant Garamond',serif;
  font-size:1rem;
  color:var(--ink-light);
  letter-spacing:.05em;
  margin-bottom:2rem;
}
.han-en .han{color:var(--vermilion);font-size:1.2rem;margin-right:.5rem}
.tag-row{display:flex;gap:.6rem;flex-wrap:wrap}
.tag{
  font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;
  padding:.5rem 1rem;
  border:1px solid var(--ink);
  background:transparent;
  font-weight:400;
}
.tag.primary{background:var(--vermilion);border-color:var(--vermilion);color:var(--paper)}
.tag.region{background:var(--ink);color:var(--paper);border-color:var(--ink)}

/* MAIN GRID */
.main-grid{
  max-width:1400px;
  margin:0 auto;
  padding:2rem 3rem 6rem;
  display:grid;
  grid-template-columns:1fr 320px;
  gap:5rem;
}

/* HERO IMAGE */
.hero-img{
  height:480px;
  margin-bottom:3rem;
  position:relative;
  background:linear-gradient(135deg,var(--paper-dark),#d4c19a);
  border:1px solid var(--line);
  overflow:hidden;
}
.hero-img::before{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(45deg,transparent,transparent 24px,rgba(26,15,8,.03) 24px,rgba(26,15,8,.03) 25px);
}
.hero-img::after{
  content:'圖 · IMAGE';
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  font-family:'Cormorant Garamond',serif;
  font-size:1.5rem;letter-spacing:.3em;
  color:rgba(26,15,8,.2);
}
.hero-img-caption{
  position:absolute;bottom:1.2rem;left:1.5rem;
  font-family:'Playfair Display',serif;
  font-style:italic;
  font-size:.85rem;
  color:var(--ink-soft);
  background:var(--paper);
  padding:.4rem .8rem;
  z-index:1;
}

/* SUMMARY BOX */
.summary{
  background:var(--paper-light);
  border-left:3px solid var(--vermilion);
  padding:2rem 2.5rem;
  margin-bottom:4rem;
  position:relative;
}
.summary::before{
  content:'❝';
  position:absolute;
  top:.5rem;left:1rem;
  font-family:'Cormorant Garamond',serif;
  font-size:3rem;
  color:var(--vermilion);
  opacity:.2;
  line-height:1;
}
.summary p{
  font-family:'Playfair Display',serif;
  font-style:italic;
  font-size:1.25rem;
  line-height:1.6;
  color:var(--ink-soft);
}

/* CONTENT TYPOGRAPHY */
.entry-content h2{
  font-family:'Cormorant Garamond',serif;
  font-size:2.5rem;
  font-weight:500;
  line-height:1.1;
  margin:3.5rem 0 1.5rem;
  display:flex;align-items:baseline;gap:1rem;
}
.entry-content h2::before{
  content:'';
  width:32px;height:1px;
  background:var(--vermilion);
  flex-shrink:0;
  align-self:center;
}
.entry-content h2 em{
  font-family:'Playfair Display',serif;
  font-style:italic;
  color:var(--vermilion);
}
.entry-content h3{
  font-family:'Cormorant Garamond',serif;
  font-size:1.6rem;
  font-style:italic;
  font-weight:500;
  margin:2.5rem 0 1rem;
  color:var(--ink-soft);
}
.entry-content p{
  font-family:'Be Vietnam Pro',sans-serif;
  font-size:1.05rem;
  line-height:1.85;
  color:var(--ink-soft);
  margin-bottom:1.3rem;
  font-weight:300;
}
.entry-content > p:first-of-type::first-letter{
  font-family:'Cormorant Garamond',serif;
  font-size:4.5rem;
  font-weight:600;
  float:left;
  line-height:.85;
  margin:.3rem .6rem 0 0;
  color:var(--vermilion);
}
.entry-content em{
  font-family:'Playfair Display',serif;
  font-style:italic;
  color:var(--ink);
}
.entry-content strong{font-weight:600;color:var(--ink)}
.entry-content a{color:var(--vermilion);text-decoration:underline}
.entry-content ul,.entry-content ol{
  margin:1rem 0 1.2rem 1.5rem;
  color:var(--ink-soft);
  font-size:1.05rem;
  line-height:1.85;
}
.entry-content li{margin-bottom:.4rem}
.entry-content blockquote{
  margin:3.5rem 0;
  padding:2rem 3rem;
  border-top:1px solid var(--line);
  border-bottom:1px solid var(--line);
  text-align:center;
}
.entry-content blockquote p{
  font-family:'Playfair Display',serif;
  font-style:italic;
  font-size:1.7rem;
  line-height:1.4;
  color:var(--ink);
}
.entry-content blockquote p::before{content:'"';color:var(--vermilion)}
.entry-content blockquote p::after{content:'"';color:var(--vermilion)}
.entry-content blockquote > p:first-of-type::first-letter{all:unset}

/* SOURCES */
.sources{
  margin-top:5rem;
  padding-top:3rem;
  border-top:1px solid var(--line);
}
.section-label{
  font-size:.7rem;
  letter-spacing:.3em;
  text-transform:uppercase;
  color:var(--vermilion);
  margin-bottom:1.5rem;
  display:flex;align-items:center;gap:1rem;
}
.section-label::after{content:'';flex:1;height:1px;background:var(--line)}
.sources ol{list-style:none;counter-reset:src}
.sources li{
  counter-increment:src;
  font-size:.9rem;
  color:var(--ink-soft);
  padding:.8rem 0 .8rem 2.5rem;
  border-bottom:1px solid var(--line-soft);
  position:relative;
  line-height:1.6;
}
.sources li::before{
  content:counter(src,decimal-leading-zero);
  position:absolute;left:0;top:.8rem;
  font-family:'Cormorant Garamond',serif;
  font-style:italic;
  color:var(--vermilion);
  font-size:.95rem;
}
.sources em{
  font-family:'Playfair Display',serif;
  font-style:italic;
  color:var(--ink);
}
.source-note{
  margin:.5rem 0 0;
  font-size:.8rem;
  line-height:1.5;
  color:var(--ink-mute);
  font-style:normal;
  font-weight:300;
}
.info-row dt.geo-key{text-transform:capitalize}
.side-sub{
  font-size:.65rem;
  letter-spacing:.2em;
  text-transform:uppercase;
  color:var(--ink-light);
  margin:0 0 .6rem;
  font-weight:500;
}
.meta-block{margin-bottom:1.2rem}
.meta-block:last-child{margin-bottom:0}
.meta-list{
  margin:0;
  padding-left:1rem;
  font-size:.82rem;
  line-height:1.55;
  color:var(--ink-soft);
}
.meta-list li{margin-bottom:.45rem}

/* RELATED */
.related{margin-top:5rem}
.related-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:2rem;
}
.related-card{
  display:block;
  transition:transform .4s ease;
}
.related-card:hover{transform:translateY(-6px)}
.related-card .img-ph{
  height:200px;
  background:linear-gradient(135deg,var(--paper-dark),#d4c19a);
  border:1px solid var(--line);
  margin-bottom:1.2rem;
  position:relative;overflow:hidden;
}
.related-card .img-ph::before{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(45deg,transparent,transparent 20px,rgba(26,15,8,.03) 20px,rgba(26,15,8,.03) 21px);
}
.related-card .img-ph::after{
  content:'圖';position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  font-family:'Cormorant Garamond',serif;
  font-size:2rem;color:rgba(26,15,8,.15);
}
.related-card .meta{
  font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;
  color:var(--vermilion);margin-bottom:.5rem;
}
.related-card h4{
  font-family:'Cormorant Garamond',serif;
  font-size:1.7rem;font-weight:500;
  line-height:1.05;margin-bottom:.5rem;
}
.related-card p{
  font-size:.85rem;
  color:var(--ink-mute);
  line-height:1.5;
}

/* SIDEBAR */
aside{position:relative}
.sidebar-sticky{
  position:sticky;top:6rem;
  display:flex;flex-direction:column;gap:1.5rem;
}
.side-card{
  background:var(--paper-light);
  border:1px solid var(--line);
  padding:1.8rem;
}
.side-label{
  font-size:.7rem;
  letter-spacing:.3em;
  text-transform:uppercase;
  color:var(--vermilion);
  margin-bottom:1.3rem;
  padding-bottom:.8rem;
  border-bottom:1px solid var(--line);
  display:flex;align-items:center;justify-content:space-between;
}
.side-label .num{
  font-family:'Cormorant Garamond',serif;
  font-style:italic;
  color:var(--ink-light);
  letter-spacing:0;
}
.info-table{display:flex;flex-direction:column;gap:.9rem}
.info-row{
  display:grid;
  grid-template-columns:90px 1fr;
  gap:1rem;
  font-size:.85rem;
  align-items:baseline;
}
.info-row dt{
  color:var(--ink-light);
  font-size:.75rem;
  letter-spacing:.1em;
