---
import SidebarCard from './SidebarCard.astro';

interface Props {
  chu_de: string[];
}
const { chu_de } = Astro.props;

const pillClasses = ['pill-coral', 'pill-teal', 'pill-blue', 'pill-amber', 'pill-violet', 'pill-green'];
---
<SidebarCard label="Chủ đề">
  <div class="flex flex-wrap gap-2">
    {chu_de.map((tag, i) => (
      <span class={`rounded-full px-3 py-1 text-xs font-medium ${pillClasses[i % pillClasses.length]}`}>
        {tag.replace(/-/g, ' ')}
      </span>
    ))}
  </div>
</SidebarCard>
