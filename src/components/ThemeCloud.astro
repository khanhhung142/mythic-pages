---
import SidebarCard from './SidebarCard.astro';

interface Props {
  themes: string[];
}
const { themes } = Astro.props;

function slugToLabel(slug: string): string {
  return slug.replace(/-/g, ' ');
}
---
<SidebarCard label="CHỦ ĐỀ">
  <div class="flex flex-wrap gap-1.5">
    {themes.map((tag) => (
      <span class="bg-gray-100 text-[#1A1A1A] rounded-full px-2.5 py-1 text-[12px] font-sans">
        {slugToLabel(tag)}
      </span>
    ))}
  </div>
</SidebarCard>
