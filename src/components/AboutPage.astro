---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n/config';
import { localePath } from '../i18n/paths';
import type { Locale } from '../i18n/config';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const pageTitle = `${t(lang, 'about.title')} — ${t(lang, 'site.title')}`;

const roadmapSteps = [1, 2, 3, 4, 5].map((n) => ({
  title: t(lang, `about.rm${n}.title`),
  desc: t(lang, `about.rm${n}.desc`),
}));
---
<BaseLayout title={pageTitle} description={t(lang, 'about.lead')} lang={lang}>
  <article class="about-page">
    <header class="about-hero">
      <div class="eyebrow">{t(lang, 'nav.about')}</div>
      <h1>{t(lang, 'about.title')}</h1>
      <p class="lead">{t(lang, 'about.lead')}</p>
    </header>

    <div class="about-prose">
      <p>{t(lang, 'about.body1')}</p>
      <p>{t(lang, 'about.body2')}</p>
    </div>

    <div class="about-cta">
      <a href={localePath(lang, '/contribute')} class="btn primary">{t(lang, 'about.cta.contribute')}</a>
      <a href="#" class="btn ghost">{t(lang, 'about.cta.report')}</a>
      <p class="cta-note">{t(lang, 'about.cta.note')}</p>
    </div>

    <section class="roadmap" aria-labelledby="roadmap-heading">
      <h2 id="roadmap-heading">{t(lang, 'about.roadmap.title')}</h2>
      <ol class="roadmap-track">
        {roadmapSteps.map((step, i) => (
          <li class="roadmap-step">
            <div class="step-marker" aria-hidden="true">
              <span class="step-num">{i + 1}</span>
            </div>
            <div class="step-body">
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>
  </article>
</BaseLayout>

<style>
  .about-page {
    max-width: 44rem;
    margin: 0 auto;
    padding: 6rem 3rem 5rem;
  }
  .about-hero .eyebrow {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--vermilion, #c53d1b);
    margin-bottom: 0.75rem;
  }
  .about-hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.25rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--ink, #1a0f08);
    margin: 0 0 1.25rem;
    line-height: 1.15;
  }
  .lead {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 1.125rem;
    line-height: 1.65;
    color: rgba(26, 15, 8, 0.85);
    margin: 0;
  }
  .about-prose {
    margin-top: 2.5rem;
  }
  .about-prose p {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 1.02rem;
    line-height: 1.75;
    color: rgba(26, 15, 8, 0.88);
    margin: 0 0 1.25rem;
  }
  .about-cta {
    margin-top: 2.5rem;
    padding: 1.75rem 0;
    border-top: 1px solid rgba(26, 15, 8, 0.12);
    border-bottom: 1px solid rgba(26, 15, 8, 0.12);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }
  .about-cta .btn {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-decoration: none;
    padding: 0.65rem 1.25rem;
    border-radius: 2px;
    transition: opacity 0.15s ease;
  }
  .about-cta .btn:hover {
    opacity: 0.88;
  }
  .about-cta .btn.primary {
    background: var(--vermilion, #c53d1b);
    color: #fff;
  }
  .about-cta .btn.ghost {
    border: 1px solid rgba(26, 15, 8, 0.25);
    color: var(--ink, #1a0f08);
    background: transparent;
  }
  .cta-note {
    width: 100%;
    margin: 0.5rem 0 0;
    font-size: 0.8rem;
    color: rgba(26, 15, 8, 0.55);
    font-family: 'Be Vietnam Pro', sans-serif;
  }
  .roadmap {
    margin-top: 3.5rem;
  }
  .roadmap h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--ink, #1a0f08);
    margin: 0 0 2rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(26, 15, 8, 0.15);
  }
  .roadmap-track {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }
  .roadmap-track::before {
    content: '';
    position: absolute;
    left: 1.125rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--vermilion, #c53d1b),
      rgba(26, 15, 8, 0.12)
    );
  }
  .roadmap-step {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 1.25rem;
    margin-bottom: 2rem;
    position: relative;
  }
  .roadmap-step:last-child {
    margin-bottom: 0;
  }
  .step-marker {
    display: flex;
    justify-content: center;
    padding-top: 0.15rem;
  }
  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: var(--paper, #f4ead5);
    border: 2px solid var(--vermilion, #c53d1b);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--vermilion, #c53d1b);
    position: relative;
    z-index: 1;
  }
  .step-body h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
    color: var(--ink, #1a0f08);
  }
  .step-body p {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
    color: rgba(26, 15, 8, 0.82);
  }
  @media (max-width: 600px) {
    .about-page {
      padding: 5rem 1.5rem 3rem;
    }
    .roadmap-track::before {
      left: 0.875rem;
    }
    .roadmap-step {
      grid-template-columns: 2rem 1fr;
      gap: 1rem;
    }
    .step-num {
      width: 1.875rem;
      height: 1.875rem;
      font-size: 0.9rem;
    }
  }
</style>
