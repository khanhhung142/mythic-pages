---
import SidebarCard from './SidebarCard.astro';

interface Props {
  lien_quan: {
    gia_dinh?: string[];
    dong_minh?: string[];
    ke_thu?: string[];
    vat_pham?: string[];
  };
}
const { lien_quan } = Astro.props;

const groups = [
  { label: 'GIA ĐÌNH', items: lien_quan.gia_dinh },
  { label: 'ĐỒNG MINH', items: lien_quan.dong_minh },
  { label: 'KẺ THÙ', items: lien_quan.ke_thu },
  { label: 'VẬT PHẨM', items: lien_quan.vat_pham },
].filter(g => g.items && g.items.length > 0);
---
{groups.length > 0 && (
  <SidebarCard label="LIÊN QUAN">
    <div class="space-y-3">
      {groups.map((group) => (
        <div>
          <p class="text-[10px] uppercase tracking-widest text-[#9CA3AF] mb-1 font-sans">{group.label}</p>
          <p class="text-[13px] text-[#1A1A1A] leading-relaxed font-sans">
            {group.items!.map((item, i) => (
              <>
                <span class="text-[#185FA5]">{item}</span>{i < group.items!.length - 1 && <span class="text-[#9CA3AF]"> · </span>}
              </>
            ))}
          </p>
        </div>
      ))}
    </div>
  </SidebarCard>
)}
