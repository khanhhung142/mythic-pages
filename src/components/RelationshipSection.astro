---
import SidebarCard from './SidebarCard.astro';

interface Props {
  relations: {
    family?: string[];
    allies?: string[];
    enemies?: string[];
    artifacts?: string[];
  };
}
const { relations } = Astro.props;

const groups = [
  { label: 'GIA ĐÌNH', items: relations.family },
  { label: 'ĐỒNG MINH', items: relations.allies },
  { label: 'KẺ THÙ', items: relations.enemies },
  { label: 'VẬT PHẨM', items: relations.artifacts },
].filter(g => g.items && g.items.length > 0);
---
{groups.length > 0 && (
  <SidebarCard label="LIÊN QUAN">
    <div class="space-y-3">
      {groups.map((group) => (
        <div>
          <p class="text-[10px] uppercase tracking-widest text-[#9CA3AF] mb-1 font-sans">{group.label}</p>
          <p class="text-[13px] text-[#1A1A1A] leading-relaxed font-sans">
            {group.items!.map((item, i) => (
              <>
                <span class="text-[#185FA5]">{item}</span>{i < group.items!.length - 1 && <span class="text-[#9CA3AF]"> · </span>}
              </>
            ))}
          </p>
        </div>
      ))}
    </div>
  </SidebarCard>
)}
