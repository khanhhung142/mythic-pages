---
import type { Locale } from '../i18n/config';
import { t } from '../i18n/config';
import { localePath } from '../i18n/paths';

interface Props {
  lang?: Locale;
}

const { lang = 'vi' } = Astro.props;
---
<footer>
  <div class="foot-grid">
    <div class="foot-brand">
      <h3>{t(lang, 'footer.brand')}</h3>
      <p>{t(lang, 'footer.desc')}</p>
    </div>
    <div class="foot-col">
      <h5>{t(lang, 'footer.explore')}</h5>
      <ul>
        <li><a href={localePath(lang, '/')}>{t(lang, 'nav.home')}</a></li>
        <li><a href={localePath(lang, '/entries')}>{t(lang, 'nav.entries')}</a></li>
        <li><a href={localePath(lang, '/#categories')}>{t(lang, 'nav.categories')}</a></li>
      </ul>
    </div>
    <div class="foot-col">
      <h5>{t(lang, 'footer.sources')}</h5>
      <ul>
        <li><a href="#">Lĩnh Nam Chích Quái</a></li>
        <li><a href="#">Việt Điện U Linh</a></li>
        <li><a href="#">Đại Việt Sử Ký</a></li>
      </ul>
    </div>
    <div class="foot-col">
      <h5>{t(lang, 'footer.contact')}</h5>
      <ul>
        <li><a href="#">{t(lang, 'footer.contribute')}</a></li>
        <li><a href="#">Github</a></li>
        <li><a href="#">Email</a></li>
      </ul>
    </div>
  </div>
  <div class="foot-bottom">
    <span>{t(lang, 'footer.copyright')}</span>
    <span>{t(lang, 'footer.made')}</span>
  </div>
</footer>

<style is:global>
footer{
  background:var(--ink);
  color:var(--paper);
  padding:5rem 3rem 2rem;
}
.foot-grid{
  display:grid;
  grid-template-columns:2fr 1fr 1fr 1fr;
  gap:3rem;
  margin-bottom:4rem;
  padding-bottom:3rem;
  border-bottom:1px solid rgba(244,234,213,.15);
}
.foot-brand h3{
  font-family:'Cormorant Garamond',serif;
  font-size:2rem;
  margin-bottom:1rem;
}
.foot-brand p{color:rgba(244,234,213,.6);max-width:380px;font-size:.9rem}
.foot-col h5{
  font-size:.75rem;letter-spacing:.2em;text-transform:uppercase;
  color:var(--gold);margin-bottom:1.2rem;
}
.foot-col ul{list-style:none}
.foot-col li{margin-bottom:.6rem}
.foot-col a{
  color:rgba(244,234,213,.7);text-decoration:none;
  font-size:.9rem;transition:color .3s;
}
.foot-col a:hover{color:var(--gold)}
.foot-bottom{
  display:flex;justify-content:space-between;
  font-size:.75rem;color:rgba(244,234,213,.5);
  letter-spacing:.1em;
}
@media (max-width:900px){
  .foot-grid{grid-template-columns:1fr 1fr;gap:2rem}
}
</style>
