---
import SidebarCard from './SidebarCard.astro';
import { CATEGORY_LABELS } from '../data/category-labels';

interface Props {
  data: Record<string, any>;
}
const { data } = Astro.props;

const vungLabels: Record<string, string> = {
  'bac': 'Bắc Bộ',
  'trung': 'Trung Bộ',
  'nam': 'Nam Bộ',
};

const gioiTinhLabels: Record<string, string> = {
  'nam': 'Nam',
  'nu': 'Nữ',
  'khong-xac-dinh': 'Không xác định',
};

const rows = [
  data.category ? { label: 'Loại', value: CATEGORY_LABELS[data.category] ?? data.category } : null,
  data.gender ? { label: 'Giới tính', value: gioiTinhLabels[data.gender] ?? data.gender } : null,
  data.era ? { label: 'Thời đại', value: data.era } : null,
  data.region ? { label: 'Vùng', value: vungLabels[data.region] ?? data.region } : null,
  data.locations?.length ? { label: 'Địa điểm', value: data.locations[0], isLink: true } : null,
  data.group ? { label: 'Nhóm', value: data.group } : null,
].filter(Boolean);
---
<SidebarCard label="THÔNG TIN">
  <dl>
    {rows.map((row) => (
      <div class="flex justify-between items-baseline py-1.5 border-b border-[#F3F4F6] last:border-0">
        <dt class="text-[13px] text-[#6B7280] shrink-0 mr-3 font-sans">{row!.label}</dt>
        <dd class="text-[13px] text-[#1A1A1A] text-right font-sans">
          {row!.isLink
            ? <a href="#" class="text-[#185FA5] hover:underline">{row!.value}</a>
            : row!.value
          }
        </dd>
      </div>
    ))}
  </dl>
</SidebarCard>
